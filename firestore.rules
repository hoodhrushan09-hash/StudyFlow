rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Primitives
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email != null && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com' || request.auth.token.firebase.sign_in_provider == 'apple.com'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+@?[a-zA-Z0-9_\\-\\.]*$'); }

    // UserProfile collection
    match /users/{email} {
      function isValidUserProfile(data) {
        return data.size() >= 4 && data.size() <= 15 &&
          data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt']) &&
          data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid &&
          data.email is string && data.email.size() <= 200 && data.email == email && data.email == request.auth.token.email &&
          data.displayName is string && data.displayName.size() <= 100 &&
          data.createdAt is number &&
          (!('onboarded' in data) || data.onboarded is bool) &&
          (!('photoBase64' in data) || (data.photoBase64 is string && data.photoBase64.size() <= 1048576)) &&
          (!('grade' in data) || (data.grade is string && data.grade.size() <= 50)) &&
          (!('ageGroup' in data) || (data.ageGroup is string && data.ageGroup.size() <= 50)) &&
          (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
          (!('provider' in data) || (data.provider is string && data.provider.size() <= 50)) &&
          (!('xp' in data) || (data.xp is number && data.xp >= 0)) &&
          (!('level' in data) || (data.level is number && data.level >= 1)) &&
          (!('coins' in data) || (data.coins is number && data.coins >= 0)) &&
          (!('streak' in data) || (data.streak is number && data.streak >= 0)) &&
          (!('updatedAt' in data) || data.updatedAt is number);
      }

      allow get: if isEmailVerified() && email == request.auth.token.email;
      allow create: if isEmailVerified() && isValidId(email) && email == request.auth.token.email &&
                    isValidUserProfile(incoming());
      allow update: if isEmailVerified() && isValidId(email) && email == request.auth.token.email &&
                    isValidUserProfile(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoBase64', 'grade', 'ageGroup', 'bio', 'provider', 'onboarded', 'xp', 'level', 'coins', 'streak', 'updatedAt']) &&
                    incoming().email == existing().email &&
                    incoming().uid == existing().uid &&
                    incoming().createdAt == existing().createdAt;
    }

    // Tasks collection
    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.size() >= 5 && data.size() <= 11 &&
          data.keys().hasAll(['userId', 'title', 'subject', 'completed', 'createdAt']) &&
          data.userId is string && data.userId.size() <= 200 && data.userId == request.auth.token.email &&
          data.title is string && data.title.size() <= 200 &&
          data.subject is string && data.subject.size() <= 100 &&
          data.completed is bool &&
          data.createdAt is number &&
          (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
          (!('dueDate' in data) || (data.dueDate is string && data.dueDate.size() <= 50)) &&
          (!('priority' in data) || (data.priority is string && data.priority.size() <= 50)) &&
          (!('reminderTime' in data) || (data.reminderTime is string && data.reminderTime.size() <= 50)) &&
          (!('subtasks' in data) || (data.subtasks is list && data.subtasks.size() <= 50));
      }

      allow list: if isEmailVerified() && resource.data.userId == request.auth.token.email;
      allow get: if isEmailVerified() && resource.data.userId == request.auth.token.email && isValidId(taskId);
      allow create: if isEmailVerified() && isValidId(taskId) && isValidTask(incoming());
      allow update: if isEmailVerified() && isValidId(taskId) && resource.data.userId == request.auth.token.email &&
                    isValidTask(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'subject', 'completed', 'description', 'dueDate', 'priority', 'reminderTime', 'subtasks']) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isEmailVerified() && isValidId(taskId) && resource.data.userId == request.auth.token.email;
    }

    // Notes collection
    match /notes/{noteId} {
      function isValidNote(data) {
        return data.size() >= 4 && data.size() <= 6 &&
          data.keys().hasAll(['userId', 'title', 'subject', 'updatedAt']) &&
          data.userId is string && data.userId.size() <= 200 && data.userId == request.auth.token.email &&
          data.title is string && data.title.size() <= 200 &&
          data.subject is string && data.subject.size() <= 100 &&
          data.updatedAt is number &&
          (!('content' in data) || (data.content is string && data.content.size() <= 1048576)) &&
          (!('taskId' in data) || (data.taskId is string && data.taskId.size() <= 128));
      }

      allow list: if isEmailVerified() && resource.data.userId == request.auth.token.email;
      allow get: if isEmailVerified() && resource.data.userId == request.auth.token.email && isValidId(noteId);
      allow create: if isEmailVerified() && isValidId(noteId) && isValidNote(incoming());
      allow update: if isEmailVerified() && isValidId(noteId) && resource.data.userId == request.auth.token.email &&
                    isValidNote(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'subject', 'taskId', 'updatedAt']) &&
                    incoming().userId == existing().userId;
      allow delete: if isEmailVerified() && isValidId(noteId) && resource.data.userId == request.auth.token.email;
    }
  }
}
